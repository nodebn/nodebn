# NodeBN — Supabase (public anon key; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NodeBN — Supabase Service Role (server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NodeBN — Email Service Configuration
EMAIL_SERVICE=resend  # Options: 'resend' or 'sendgrid'
EMAIL_FROM=hello@yourdomain.com

# Email API Keys (choose one based on EMAIL_SERVICE)
RESEND_API_KEY=your-resend-api-key
SENDGRID_API_KEY=your-sendgrid-api-key

# NodeBN — App Configuration
NEXT_PUBLIC_APP_URL=https://yourdomain.com
